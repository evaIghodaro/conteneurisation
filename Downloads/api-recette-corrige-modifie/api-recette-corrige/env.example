# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/recettes-du-monde

# Secret pour les tokens JWT (générez une chaîne sécurisée longue)
JWT_SECRET=votre-secret-jet-très-sécurisé-à-remplacer-en-production

# URL de l'application (pour NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=votre-secret-nextauth-à-remplacer

# Configuration optionnelle pour l'envoi d'emails (futur)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=votre-email@gmail.com
# EMAIL_PASS=votre-mot-de-passe-app

# Configuration du stockage (futur)
# UPLOAD_PROVIDER=local # ou cloudinary, aws-s3
# CLOUDINARY_CLOUD_NAME=votre-cloud-name
# CLOUDINARY_API_KEY=votre-api-key
# CLOUDINARY_API_SECRET=votre-api-secret

# Analytics (optionnel)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Mode de l'application
NODE_ENV=development
